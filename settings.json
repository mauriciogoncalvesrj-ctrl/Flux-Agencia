{
  "permissions": {
    "allow": [
      "WebFetch(domain:www.anthropic.com)",
      "Bash(git*)",
      "PowerShell(git*)"
    ],
    "additionalDirectories": [
      "C:\\Users\\windows\\.claude\\plans"
    ]
  },
  "autoUpdatesChannel": "latest",
  "theme": "dark",
  "effortLevel": "high",
  "mcpServers": {
    "hostinger-api": {
      "command": "hostinger-api-mcp",
      "env": {
        "DEBUG": "false",
        "API_TOKEN": "${HOSTINGER_API_TOKEN}"
      }
    }
  }
}
